# API Configuration (Backend Server)
VITE_API_URL=https://campus-server-three.vercel.app/api

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ========================================
# GitHub Secrets Setup Instructions
# ========================================
# To deploy to GitHub Pages, add these variables as secrets:
# 1. Go to: https://github.com/eshwargit2/collegecircle/settings/secrets/actions
# 2. Click "New repository secret"
# 3. Add the following secrets:
#    - Name: VITE_API_URL              | Value: https://clg-server.vercel.app/api
#    - Name: VITE_SUPABASE_URL         | Value: your Supabase project URL
#    - Name: VITE_SUPABASE_ANON_KEY    | Value: your Supabase anonymous key
